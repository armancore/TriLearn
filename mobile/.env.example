# Development defaults only.
# Android emulator users may need http://10.0.2.2:5000 instead of localhost.
# Physical devices need your computer's LAN IP, for example http://192.168.1.81:5000.
EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1
EXPO_PUBLIC_SOCKET_URL=http://localhost:5000
EXPO_PUBLIC_WEB_URL=http://localhost:5173

# Production release builds must not use localhost or plain HTTP.
# Set these to your deployed HTTPS API, socket, and web origins before building APK/IPA artifacts.
