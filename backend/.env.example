# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/trilearn

# JWT secrets - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here
LOGIN_CAPTCHA_SECRET=your-login-captcha-secret-here

# Secret used to sign student QR codes
QR_SIGNING_SECRET=your-qr-secret-here

# Optional: comma-separated kid:secret entries for QR signing key rotation
QR_SIGNING_SECRET_KEYS=
QR_SIGNING_ACTIVE_KID=

# Frontend URL (used for CORS, password reset links, and Socket.IO browser connections)
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development

# Optional: allow Socket.IO requests without an Origin header in local development only
ALLOW_SOCKET_NO_ORIGIN=false

# Optional: server port
PORT=5000

# Optional: Express trust proxy setting (for reverse proxies/load balancers)
TRUST_PROXY=

# Optional: bearer token for external health checks
HEALTHCHECK_KEY=

# Optional: set to 'true' to allow student self-registration
OPEN_REGISTRATION=false

# Optional: attendance timezone for date boundaries
ATTENDANCE_TIMEZONE=Asia/Kathmandu

# Optional: process timezone for deployment environments
TZ=Asia/Kathmandu

# Optional: Redis URL for shared rate limiting in production
REDIS_URL=

# Firebase Cloud Messaging server key (required for push notifications)
FCM_SERVER_KEY=

# Optional: SMTP settings for email delivery via Resend
RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=465
RESEND_SMTP_USER=resend
RESEND_SMTP_PASS=

# Optional: sender address for outgoing emails
MAIL_FROM=TriLearn <no-reply@yourdomain.com>

# Optional: set to 'true' to enable password reset emails (requires SMTP config)
ENABLE_PASSWORD_RESET=false

# Optional: set to 'true' only for local troubleshooting; not allowed in production
DEBUG_ERRORS=false

# Optional: disable Express rate limits in local development; not allowed in production
DISABLE_RATE_LIMITS=false

# Optional: login rate limit settings
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# Optional: bcrypt salt rounds (default 12, range 10-16)
BCRYPT_SALT_ROUNDS=12

# Optional: token expiry settings
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# Optional: how often to clean up expired refresh tokens (ms), default 6 hours
REFRESH_TOKEN_CLEANUP_INTERVAL_MS=21600000

# Optional: attendance background sync interval (ms), default 5 minutes
ATTENDANCE_SYNC_INTERVAL_MS=300000

# Optional: notification worker concurrency
NOTIFICATION_WORKER_CONCURRENCY=2

# Optional: audit log retention in days
AUDIT_LOG_RETENTION_DAYS=180

# Optional: audit log cleanup interval (ms), default 24 hours
AUDIT_LOG_CLEANUP_INTERVAL_MS=86400000

# Optional: file upload size limits in bytes per role
MAX_PDF_UPLOAD_BYTES_ADMIN=15728640
MAX_PDF_UPLOAD_BYTES_COORDINATOR=15728640
MAX_PDF_UPLOAD_BYTES_INSTRUCTOR=15728640
MAX_PDF_UPLOAD_BYTES_STUDENT=10485760

# Optional: Socket.IO event rate limit settings
SOCKET_EVENT_RATE_LIMIT_MAX=60
SOCKET_EVENT_RATE_LIMIT_WINDOW_MS=10000

# Optional: Prisma pool settings
PGPOOL_MAX=10
PGPOOL_MIN=0
PGPOOL_IDLE_TIMEOUT_MS=10000
PGPOOL_CONNECTION_TIMEOUT_MS=10000
PGPOOL_MAX_USES=0

# Optional: upload storage settings
UPLOAD_DIR=uploads
UPLOAD_PUBLIC_PATH=/uploads
UPLOAD_BASE_URL=

# Optional: default temporary password for new student accounts
DEFAULT_STUDENT_PASSWORD=
