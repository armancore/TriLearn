generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================================
// USER & AUTH
// ================================

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  phone     String?
  address   String?
  avatar    String?
  isActive  Boolean  @default(true)
  mustChangePassword Boolean @default(false)
  profileCompleted Boolean @default(false)
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  suspensionReason String?
  suspendedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  student    Student?
  instructor Instructor?
  admin      Admin?
  coordinator Coordinator?
  notices    Notice[]
  refreshTokens RefreshToken[]
  auditLogs  AuditLog[]

  @@index([role])
  @@index([isActive])
}

enum Role {
  ADMIN
  COORDINATOR
  GATEKEEPER
  INSTRUCTOR
  STUDENT
}

// ================================
// PROFILES
// ================================

model Admin {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}

model Instructor {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  department String?
  subjects   Subject[]
  attendances Attendance[]
  assignments Assignment[]
  marks      Mark[]
  materials  StudyMaterial[]
  routines     Routine[]

  @@index([department])
}

model Coordinator {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  department String?
}

model Student {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  rollNumber   String   @unique
  semester     Int
  section      String?
  department   String?
  guardianName String?
  guardianPhone String?
  dateOfBirth  DateTime?
  enrolledAt   DateTime @default(now())
  attendances  Attendance[]
  submissions  Submission[]
  marks        Mark[]
  subjectEnrollments SubjectEnrollment[]

  @@index([semester])
  @@index([department])
  @@index([semester, department])
}

// ================================
// ACADEMIC
// ================================

model Subject {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  description  String?
  semester     Int
  department   String?
  instructorId String?
  instructor   Instructor? @relation(fields: [instructorId], references: [id])
  createdAt    DateTime @default(now())

  attendances  Attendance[]
  assignments  Assignment[]
  materials    StudyMaterial[]
  marks        Mark[]
  routines     Routine[]
  enrollments  SubjectEnrollment[]

  @@index([semester])
  @@index([department])
  @@index([instructorId])
}

model SubjectEnrollment {
  id        String   @id @default(uuid())
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([subjectId, studentId])
  @@index([studentId])
  @@index([subjectId])
}

// ================================
// ATTENDANCE
// ================================

model Attendance {
  id           String   @id @default(uuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id])
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id])
  date         DateTime @default(now())
  status       AttendanceStatus @default(PRESENT)
  qrCode       String?
  createdAt    DateTime @default(now())

  @@index([studentId, subjectId, date])
  @@index([subjectId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

// ================================
// ASSIGNMENTS
// ================================

model Assignment {
  id           String   @id @default(uuid())
  title        String
  description  String
  questionPdfUrl String?
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id])
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id])
  dueDate      DateTime
  totalMarks   Int      @default(100)
  createdAt    DateTime @default(now())

  submissions  Submission[]

  @@index([subjectId])
  @@index([instructorId])
  @@index([dueDate])
}

model Submission {
  id           String   @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  fileUrl      String?
  note         String?
  obtainedMarks Int?
  submittedAt  DateTime @default(now())
  status       SubmissionStatus @default(SUBMITTED)

  @@index([assignmentId])
  @@index([studentId])
  @@index([status])
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  LATE
}

// ================================
// MARKS / EXAM
// ================================

model Mark {
  id           String   @id @default(uuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id])
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id])
  examType     ExamType
  totalMarks   Int
  obtainedMarks Int
  remarks      String?
  createdAt    DateTime @default(now())

  @@index([studentId, subjectId])
}

enum ExamType {
  INTERNAL
  MIDTERM
  FINAL
  PRACTICAL
}

// ================================
// STUDY MATERIAL
// ================================

model StudyMaterial {
  id           String   @id @default(uuid())
  title        String
  description  String?
  fileUrl      String
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id])
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id])
  createdAt    DateTime @default(now())

  @@index([subjectId])
  @@index([instructorId])
}

// ================================
// NOTICES & EVENTS
// ================================

model Notice {
  id        String     @id @default(uuid())
  title     String
  content   String
  type      NoticeType @default(GENERAL)
  postedBy  String
  user      User       @relation(fields: [postedBy], references: [id])
  createdAt DateTime   @default(now())

  @@index([type])
  @@index([createdAt])
}

enum NoticeType {
  GENERAL
  EXAM
  HOLIDAY
  EVENT
  URGENT
}
// ================================
// CLASS ROUTINE
// ================================

model Routine {
  id           String   @id @default(uuid())
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id])
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id])
  dayOfWeek    DayOfWeek
  startTime    String
  endTime      String
  room         String?
  createdAt    DateTime @default(now())

  @@index([dayOfWeek])
  @@index([subjectId])
  @@index([instructorId])
}

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorRole  Role?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}
