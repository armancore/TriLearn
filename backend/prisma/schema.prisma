generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================================
// USER & AUTH
// ================================

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  phone     String?
  address   String?
  avatar    String?
  isActive  Boolean  @default(true)
  failedLoginAttempts Int @default(0)
  lockedUntil DateTime?
  mustChangePassword Boolean @default(false)
  profileCompleted Boolean @default(false)
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  passwordChangedAt DateTime?
  suspensionReason String?
  suspendedAt DateTime?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  student    Student?
  instructor Instructor?
  admin      Admin?
  coordinator Coordinator?
  notices    Notice[]
  notifications Notification[]
  deviceTokens DeviceToken[]
  refreshTokens RefreshToken[]
  auditLogs  AuditLog[]

  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@index([passwordResetTokenHash])
}

enum Role {
  ADMIN
  COORDINATOR
  GATEKEEPER
  INSTRUCTOR
  STUDENT
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  CONVERTED
}

// ================================
// PROFILES
// ================================

model Admin {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Instructor {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  department String?
  departmentDetails Department? @relation("InstructorDepartment", fields: [department], references: [name], onDelete: SetNull, onUpdate: Cascade)
  departmentMemberships InstructorDepartmentMembership[]
  subjects   Subject[]
  attendances Attendance[]
  assignments Assignment[]
  marks      Mark[]
  materials  StudyMaterial[]
  routines     Routine[]

  @@index([department])
}

model InstructorDepartmentMembership {
  id           String     @id @default(uuid())
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([instructorId, departmentId])
  @@index([instructorId])
  @@index([departmentId])
}

model Coordinator {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  department String?
  departmentDetails Department? @relation("CoordinatorDepartment", fields: [department], references: [name], onDelete: SetNull, onUpdate: Cascade)
}

model Student {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rollNumber   String   @unique
  semester     Int
  isGraduated  Boolean  @default(false)
  graduationYear Int?
  graduatedAt  DateTime?
  section      String?
  department   String?
  departmentDetails Department? @relation("StudentDepartment", fields: [department], references: [name], onDelete: SetNull, onUpdate: Cascade)
  fatherName   String?
  motherName   String?
  fatherPhone  String?
  motherPhone  String?
  bloodGroup   String?
  localGuardianName String?
  localGuardianAddress String?
  localGuardianPhone String?
  permanentAddress String?
  temporaryAddress String?
  dateOfBirth  DateTime?
  enrolledAt   DateTime @default(now())
  attendances  Attendance[]
  absenceTickets AbsenceTicket[]
  submissions  Submission[]
  marks        Mark[]
  subjectEnrollments SubjectEnrollment[]

  @@index([semester])
  @@index([department])
  @@index([semester, department])
  @@index([isGraduated])
}

// ================================
// ACADEMIC
// ================================

model Subject {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  description  String?
  semester     Int
  department   String?
  departmentDetails Department? @relation("SubjectDepartment", fields: [department], references: [name], onDelete: SetNull, onUpdate: Cascade)
  instructorId String?
  instructor   Instructor? @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  attendances  Attendance[]
  assignments  Assignment[]
  materials    StudyMaterial[]
  marks        Mark[]
  routines     Routine[]
  enrollments  SubjectEnrollment[]

  @@index([semester])
  @@index([department])
  @@index([instructorId])
}

model SubjectEnrollment {
  id        String   @id @default(uuid())
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([subjectId, studentId])
  @@index([studentId])
  @@index([subjectId])
}

// ================================
// ATTENDANCE
// ================================

model Attendance {
  id           String   @id @default(uuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  date         DateTime
  status       AttendanceStatus @default(PRESENT)
  qrCode       String?
  createdAt    DateTime @default(now())
  absenceTicket AbsenceTicket?

  @@index([subjectId, date])
  @@unique([studentId, subjectId, date])
}

model GateScanWindow {
  id               String   @id @default(uuid())
  title            String?
  dayOfWeek        DayOfWeek
  startTime        String
  endTime          String
  allowedSemesters Int[]
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([dayOfWeek, isActive])
}

model AttendanceHoliday {
  id          String   @id @default(uuid())
  date        DateTime @unique
  title       String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date, isActive])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model AbsenceTicket {
  id           String   @id @default(uuid())
  attendanceId String   @unique
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reason       String
  status       AbsenceTicketStatus @default(PENDING)
  response     String?
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([studentId, status])
  @@index([status, createdAt])
}

enum AbsenceTicketStatus {
  PENDING
  APPROVED
  REJECTED
}

// ================================
// ASSIGNMENTS
// ================================

model Assignment {
  id           String   @id @default(uuid())
  title        String
  description  String
  questionPdfUrl String?
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  dueDate      DateTime
  totalMarks   Int      @default(100)
  createdAt    DateTime @default(now())

  submissions  Submission[]

  @@index([subjectId])
  @@index([instructorId])
  @@index([dueDate])
}

model Submission {
  id           String   @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fileUrl      String?
  note         String?
  obtainedMarks Int?
  feedback     String?
  submittedAt  DateTime @default(now())
  status       SubmissionStatus @default(SUBMITTED)

  @@index([assignmentId])
  @@index([studentId])
  @@index([status])
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  LATE
}

// ================================
// MARKS / EXAM
// ================================

model Mark {
  id           String   @id @default(uuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  examType     ExamType
  totalMarks   Int
  obtainedMarks Int
  grade        String
  gradePoint   Float
  remarks      String?
  isPublished  Boolean  @default(false)
  publishedAt  DateTime?
  publishedBy  String?
  createdAt    DateTime @default(now())

  @@index([studentId, subjectId])
  @@index([subjectId, isPublished])
  @@unique([studentId, subjectId, examType])
}

enum ExamType {
  INTERNAL
  MIDTERM
  FINAL
  PREBOARD
  PRACTICAL
}

// ================================
// STUDY MATERIAL
// ================================

model StudyMaterial {
  id           String   @id @default(uuid())
  title        String
  description  String?
  fileUrl      String
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([subjectId])
  @@index([instructorId])
}

// ================================
// NOTICES & EVENTS
// ================================

model Notice {
  id        String     @id @default(uuid())
  title     String
  content   String
  type      NoticeType @default(GENERAL)
  audience  NoticeAudience @default(ALL)
  targetDepartment String?
  targetSemester Int?
  postedBy  String
  user      User       @relation(fields: [postedBy], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@index([type])
  @@index([audience])
  @@index([targetDepartment, targetSemester])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  metadata  Json?
  dedupeKey String?          @unique
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt])
  @@index([type, createdAt])
}

enum NoticeType {
  GENERAL
  EXAM
  HOLIDAY
  EVENT
  URGENT
}

enum NoticeAudience {
  ALL
  STUDENTS
  INSTRUCTORS_ONLY
}

enum NotificationType {
  NOTICE_POSTED
  ASSIGNMENT_DUE
  ABSENCE_TICKET_REVIEWED
  MARKS_PUBLISHED
  ROUTINE_UPDATED
}
// ================================
// CLASS ROUTINE
// ================================

model Routine {
  id           String   @id @default(uuid())
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  department   String?
  semester     Int
  section      String?
  combinedGroupId String?
  dayOfWeek    DayOfWeek
  startTime    String
  endTime      String
  room         String?
  createdAt    DateTime @default(now())

  @@index([dayOfWeek])
  @@index([department, semester, section, dayOfWeek])
  @@index([subjectId])
  @@index([instructorId])
  @@index([combinedGroupId])
}

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  students    Student[] @relation("StudentDepartment")
  instructors Instructor[] @relation("InstructorDepartment")
  instructorMemberships InstructorDepartmentMembership[]
  coordinators Coordinator[] @relation("CoordinatorDepartment")
  subjects    Subject[] @relation("SubjectDepartment")
  sections    DepartmentSection[]
}

model DepartmentSection {
  id           String     @id @default(uuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  semester     Int
  section      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([departmentId, semester])
  @@index([departmentId, section])
  @@unique([departmentId, semester, section])
}

model StudentApplication {
  id                  String            @id @default(uuid())
  fullName            String
  email               String            @unique
  phone               String
  fatherName          String
  motherName          String
  fatherPhone         String
  motherPhone         String
  bloodGroup          String?
  localGuardianName   String
  localGuardianAddress String
  localGuardianPhone  String
  permanentAddress    String
  temporaryAddress    String
  dateOfBirth         DateTime
  preferredDepartment String
  preferredSemester   Int
  preferredSection    String?
  status              ApplicationStatus @default(PENDING)
  reviewedAt          DateTime?
  reviewedBy          String?
  linkedUserId        String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([status])
  @@index([preferredDepartment, preferredSemester])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorRole  Role?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  ipAddress String?
  userAgent String?
  lastUsedAt DateTime?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, revokedAt, expiresAt])
}

enum DevicePlatform {
  IOS
  ANDROID
}

model DeviceToken {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String         @unique
  platform  DevicePlatform
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId])
  @@index([platform])
}
